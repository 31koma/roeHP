{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "news/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "lunch/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "dinner/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "english/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "access/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.svg",
      "use": "@vercel/static"
    },
    {
      "src": "site.webmanifest",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/news/upload",
      "dest": "/api/news/upload.js"
    },
    {
      "src": "/api/news/create",
      "dest": "/api/news/create.js"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.js"
    },
    {
      "src": "/news/?",
      "dest": "/news/index.html"
    },
    {
      "src": "/lunch/?",
      "dest": "/lunch/index.html"
    },
    {
      "src": "/dinner/?",
      "dest": "/dinner/index.html"
    },
    {
      "src": "/english/?",
      "dest": "/english/index.html"
    },
    {
      "src": "/access/?",
      "dest": "/access/index.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
